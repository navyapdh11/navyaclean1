# Render Deployment Environment Variables
# Copy this file to .env.deploy and fill in the values

# Your Render API key (get from https://dashboard.render.com/user/settings#api-keys)
RENDER_API_KEY=your_render_api_key_here

# Your Render owner/team ID (get from dashboard URL or API)
RENDER_OWNER_ID=your_owner_id_here
